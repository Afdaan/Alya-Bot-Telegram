# Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here  # Change this to your actual Telegram Bot Token

# Admin Configuration
ADMIN_IDS=your_telegram_ids  # Can contain multiple IDs separated by commas, e.g., 12312331212,12345678,87654321

# LLM Provider Selection - Determines which language model to use
# Options: "gemini" or "self"
LLM_PROVIDER=gemini

# Gemini API Configuration
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2  # Add multiple keys for rotation
GEMINI_MODEL=gemini-2.0-flash  # Available models: gemini-1.0-pro, gemini-1.5-flash, gemini-2.0-flash
MAX_OUTPUT_TOKENS=8098  # Maximum tokens in generated responses
TEMPERATURE=0.7  # Controls randomness (0.0 = deterministic, 1.0 = very random)
TOP_K=40  # Limits token selection to top K options
TOP_P=0.95  # Nucleus sampling parameter

# Self-hosted LLM Configuration (used when LLM_PROVIDER=self)
# Path to your GGUF file
LLM_MODEL_PATH=models/openchat-3.5-0106-Q5_K.gguf
LLM_CONTEXT_SIZE=4096  # Context window size
LLM_N_GPU_LAYERS=0  # Number of layers to offload to GPU (0 = CPU only)
LLM_N_THREADS=4  # CPU threads to use
LLM_N_BATCH=512  # Batch size for inference
LLM_TEMP=0.7  # Temperature for self-hosted model
LLM_TOP_P=0.95  # Top-p for self-hosted model

# NLP Models Configuration
# for using local models, set to absolute or relative path
# Example relative (which will be run from the root project):
NLP_MODELS_DIR=data/models
# Jika mengosongkan, bot akan download model dari HuggingFace
# EMOTION_DETECTION_MODEL=./data/models/emotion-model  # Uncomment for using local model
# SENTIMENT_MODEL=./data/models/sentiment-model        # Uncomment For using local model

# Database Configuration (Optional if using a path other than default)
# SQLITE_DB_PATH=custom/path/to/alya.db

# Logging Configuration (Optional)
# LOG_LEVEL=DEBUG

# Memory Configuration
# MEMORY_EXPIRY_DAYS=7  # Number of days to keep conversation history
# MAX_CONTEXT_MESSAGES=20  # Maximum number of messages to include in context
# SUMMARY_INTERVAL=50  # Generate summary after this many messages

# Feature Toggles
# FEATURES={"emotion_detection": true, "memory": true, "nlp": true}

# Later if developed further, you can add other APIs like SauceNAO, Weather API, etc.
# SAUCENAO_API_KEY=your_saucenao_api_key
# WEATHER_API_KEY=your_weather_api_key
# GOOGLE_CSE_ID=your_google_cse_id
# GOOGLE_API_KEY=your_google_api_key
